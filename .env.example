# CTFd
CTFD_PORT=8000
CTFD_SECRET_KEY=change-me-ctfd-secret
CTFD_DB_NAME=ctfd
CTFD_DB_USER=ctfd
CTFD_DB_PASSWORD=change-me-ctfd-db-password
CTFD_DB_ROOT_PASSWORD=change-me-root-password

# Validation service
VAL_API_PORT=8080
VAL_DATABASE_URL=sqlite:////data/validation.db
VAL_UPLOAD_DIR=/data/uploads
VAL_EXTRACT_DIR=/data/extracted
VAL_CTFD_BASE_URL=http://ctfd:8000
VAL_CTFD_API_TOKEN=replace-with-ctfd-admin-api-token
VAL_SSH_PRIVATE_KEY_FILE=./secrets/id_ed25519
VAL_SSH_PRIVATE_KEY_PATH=/run/keys/id_ed25519
VAL_SSH_USERNAME=student
VAL_SSH_CONNECT_TIMEOUT=15
VAL_SSH_COMMAND_TIMEOUT=60
VAL_DEFAULT_VERIFY_TIMEOUT=30

# JSON mapping of student group -> VM host/IP.
# Example: {"group-1":"10.10.1.21","group-2":"10.10.1.22"}
VAL_GROUP_VM_MAP={"group-1":"10.0.0.101"}
