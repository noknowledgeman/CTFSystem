# CTF Backend – copy to .env and adjust
# Use a Python venv: python -m venv venv && source venv/bin/activate

# Database (SQLite path; relative to backend dir when running uvicorn from backend)
DATABASE_URL=sqlite:///./ctf.db

# JWT / session
SECRET_KEY=change-me-in-production-use-long-random-string

# Optional: default admin account (created on first run if no admin exists)
DEFAULT_ADMIN_PASSWORD=admin

# Optional: CORS / frontend (for local dev the frontend may run on another port)
# BACKEND_URL=http://localhost:8000
